FROM php:8.2-apache

# 1. Instala as extensões do MySQL
RUN docker-php-ext-install mysqli pdo pdo_mysql

# 2. Ativa o mod_rewrite
RUN a2enmod rewrite

# 3. Configura o Apache para usar o MPM Prefork, que é mais compatível com o PHP
RUN a2dismod mpm_event || true
RUN a2dismod mpm_worker || true
RUN a2enmod mpm_prefork

# 3. Define o diretório padrão
WORKDIR /var/www/html

# 4. Copia os arquivos do projeto
COPY . /var/www/html/

# 5. Ajusta as permissões dos arquivos
RUN chown -R www-data:www-data /var/www/html

# 6. Altera a porta de 80 para 8080 nos arquivos de configuração do Apache
RUN sed -i 's/80/8080/g' /etc/apache2/sites-available/000-default.conf /etc/apache2/ports.conf

# 7. Informa a porta correta
EXPOSE 8080